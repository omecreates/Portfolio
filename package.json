{
  "name": "ece-engineer-portfolio-backend",
  "version": "1.0.0",
  "description": "Backend API server for Shahid's portfolio",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "nodemon": "^3.1.0"
  }
}
